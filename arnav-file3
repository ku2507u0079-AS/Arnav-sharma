<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Access | CampusConnect</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="wrapper">
        <div class="hero-section">
            <h1>🔒 Admin Portal</h1>
            <p>Secure access for event coordinators</p>
        </div>

        <div class="card">
            <h2>Administrator Login</h2>

            <form id="adminForm">
                <div class="input-group">
                    <label>👨‍💼 Username</label>
                    <input type="text" id="username" placeholder="Enter admin username" required>
                </div>

                <div class="input-group">
                    <label>🔑 Password</label>
                    <input type="password" id="password" placeholder="Enter password" required>
                </div>

                <button type="submit" class="btn-primary">🚪 Login</button>
            </form>

            <div id="adminAlert" class="alert"></div>

            <div class="demo-box">
                <strong>📌 Demo Credentials:</strong><br>
                Username: <code>admin</code><br>
                Password: <code>admin123</code>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>

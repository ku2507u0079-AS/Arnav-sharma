const API_BASE = "http://localhost:3000/api";

// ==================== REGISTRATION PAGE ====================
const registerForm = document.getElementById("registerForm");
if (registerForm) {
    registerForm.addEventListener("submit", async function(e) {
        e.preventDefault();
        
        const formData = {
            full_name: document.getElementById("fullName").value,
            student_number: document.getElementById("studentId").value,
            email_id: document.getElementById("email").value,
            mobile: document.getElementById("phone").value || "Not provided",
            event_title: document.getElementById("event").value,
            faculty: document.getElementById("department").value || "Not specified",
            semester: document.getElementById("year").value || "Not specified"
        };
        
        if (!formData.event_title) {
            showAlert("Please select an event", "error");
            return;
        }
        
        try {
            const response = await fetch(${API_BASE}/register, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(formData)
            });
            const result = await response.json();
            
            if (result.success) {
                showAlert("✅ " + result.message, "success");
                registerForm.reset();
            } else {
                showAlert("❌ " + result.message, "error");
            }
        } catch (error) {
            showAlert("⚠️ Server error. Make sure backend is running on port 3000", "error");
        }
    });
}

// ==================== ADMIN LOGIN ====================
const adminForm = document.getElementById("adminForm");
if (adminForm) {
    adminForm.addEventListener("submit", function(e) {
        e.preventDefault();
        const username = document.getElementById("username").value;
        const password = document.getElementById("password").value;
        
        if (username === "admin" && password === "admin123") {
            localStorage.setItem("adminAuth", "true");
            window.location.href = "dashboard.html";
        } else {
            showAdminAlert("❌ Invalid credentials! Use admin/admin123", "error");
        }
    });
}

// ==================== DASHBOARD ====================
let participantsData = [];

if (window.location.pathname.includes("dashboard.html")) {
    // Check authentication
    if (localStorage.getItem("adminAuth") !== "true") {
        window.location.href = "admin-login.html";
    }
    
    loadParticipants();
}

async function loadParticipants() {
    try {
        const response = await fetch(${API_BASE}/participants);
        const data = await response.json();
        participantsData = data;
        
        // Update stats
        document.getElementById("totalReg").textContent = data.length;
        const uniqueEvents = new Set(data.map(p => p.event_title));
        document.getElementById("totalEvents").textContent = uniqueEvents.size;
        const uniqueStudents = new Set(data.map(p => p.student_number));
        document.getElementById("totalStudents").textContent = uniqueStudents.size;
        
        renderTable(data);
    } catch (error) {
        document.getElementById("participantsList").innerHTML = 
            '<div style="padding: 40px; text-align: center; color: red;">⚠️ Failed to load data. Start the backend with: node server.js</div>';
    }
}

function renderTable(data) {
    if (data.length === 0) {
        document.getElementById("participantsList").innerHTML = 
            '<div style="padding: 40px; text-align: center; color: #64748b;">📭 No registrations yet. Submit registrations from index.html</div>';
        return;
    }
    
    let html = `<table>
        <thead>
            <tr>
                <th>ID</th><th>Full Name</th><th>Student ID</th><th>Email</th>
                <th>Event</th><th>Department</th><th>Semester</th><th>Registered On</th><th>Action</th>
            </tr>
        </thead>
        <tbody>`;
    
    data.forEach(p => {
        html += `
            <tr>
                <td>${p.id}</td>
                <td>${escapeHtml(p.full_name)}</td>
                <td>${escapeHtml(p.student_number)}</td>
                <td>${escapeHtml(p.email_id)}</td>
                <td><span class="event-tag">${escapeHtml(p.event_title)}</span></td>
                <td>${escapeHtml(p.faculty || 'N/A')}</td>
                <td>${escapeHtml(p.semester || 'N/A')}</td>
                <td>${p.registration_time ? new Date(p.registration_time).toLocaleString() : 'N/A'}</td>
                <td><button class="delete-btn" onclick="deleteParticipant(${p.id})">🗑️ Delete</button></td>
            </tr>
        `;
    });
    
    html += </tbody></table>;
    document.getElementById("participantsList").innerHTML = html;
}

window.filterParticipants = function() {
    const searchTerm = document.getElementById("searchField").value.toLowerCase();
    const filtered = participantsData.filter(p => 
        p.full_name.toLowerCase().includes(searchTerm) ||
        p.student_number.toLowerCase().includes(searchTerm) ||
        p.email_id.toLowerCase().includes(searchTerm)
    );
    renderTable(filtered);
};

window.deleteParticipant = async function(id) {
    if (confirm("⚠️ Are you sure you want to delete this registration?")) {
        try {
            await fetch(${API_BASE}/delete/${id}, { method: "DELETE" });
            loadParticipants();
        } catch (error) {
            alert("Delete failed");
        }
    }
};

window.exportData = function() {
    if (participantsData.length === 0) {
        alert("No data to export");
        return;
    }
    
    let csv = "Name,Student ID,Email,Phone,Event,Department,Semester,Date\n";
    participantsData.forEach(p => {
        csv += "${p.full_name}","${p.student_number}","${p.email_id}","${p.mobile || 'N/A'}","${p.event_title}","${p.faculty || 'N/A'}","${p.semester || 'N/A'}","${p.registration_time || 'N/A'}"\n;
    });
    
    const blob = new Blob([csv], { type: "text/csv" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = registrations_${new Date().toISOString().split("T")[0]}.csv;
    a.click();
    URL.revokeObjectURL(url);
};

window.logoutAdmin = function() {
    localStorage.removeItem("adminAuth");
    window.location.href = "admin-login.html";
};

// ==================== HELPER FUNCTIONS ====================
function showAlert(message, type) {
    const alertDiv = document.getElementById("alertBox");
    if (alertDiv) {
        alertDiv.textContent = message;
        alertDiv.className = alert ${type};
        alertDiv.style.display = "block";
        setTimeout(() => {
            alertDiv.style.display = "none";
        }, 3000);
    }
}

function showAdminAlert(message, type) {
    const alertDiv = document.getElementById("adminAlert");
    if (alertDiv) {
        alertDiv.textContent = message;
        alertDiv.className = alert ${type};
        alertDiv.style.display = "block";
    }
}

function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
    });
}
